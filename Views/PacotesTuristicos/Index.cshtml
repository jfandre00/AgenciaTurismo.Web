@model IEnumerable<AgenciaTurismo.Web.Models.PacoteTuristico>

@{
    ViewData["Title"] = "Pacotes Turísticos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gerenciar Pacotes Turísticos</h2>
        <a asp-action="Create" class="btn btn-success">+ Novo Pacote</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Destino / Título</th>
                        <th>Data de Início</th>
                        <th>Vagas</th>
                        <th>Valor (Por Pessoa)</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold align-middle">
                                @Html.DisplayFor(modelItem => item.Titulo)
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-info text-dark">
                                    @item.DataInicio.ToString("dd/MM/yyyy")
                                </span>
                            </td>
                            <td class="align-middle">
                                @Html.DisplayFor(modelItem => item.CapacidadeMaxima) pessoas
                            </td>
                            <td class="align-middle text-success fw-bold">
                                R$ @item.Preco.ToString("N2")
                            </td>
                            <td class="text-center align-middle">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>